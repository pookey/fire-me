# AWS
AWS_PROFILE=your-aws-profile

# Domain (for CDK deployment)
FINTRACK_DOMAIN=fintrack.yourdomain.com
FINTRACK_HOSTED_ZONE_ID=YOUR_HOSTED_ZONE_ID
FINTRACK_ZONE_NAME=yourdomain.com

# Cognito (auto-populated after first deploy, or set manually)
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_USERNAME=your-email@example.com
FINTRACK_PASSWORD=your-password

# API (auto-populated after first deploy, or set manually)
API_BASE_URL=https://your-api-id.execute-api.eu-west-2.amazonaws.com
